{
  "manifest_version": 3,
  "name": "quick cobalt",
  "description": "Quickly download media of the active tab through cobalt.tools",
  "version": "1.1",
  "permissions": [
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://cobalt.tools/"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "Open in cobalt.tools"
  },
  "icons": {
    "128": "icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "quick-cobalt@addons.mozilla.org",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}